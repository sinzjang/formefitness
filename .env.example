# Forme 환경변수 템플릿 (이 파일은 git에 커밋, 실제 값은 .env에 작성)

# 로컬 dev client — 앱 아이콘 splash-icon_dev.png 사용 (app.config.ts)
APP_VARIANT=development

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Google OAuth — Cloud Console Web + iOS 클라이언트 ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com

# Apple Sign In → Supabase Secret JWT 생성용 (scripts/generateAppleSecret.js)
# Team ID: Apple Developer → Membership details
# Services ID: Identifiers → Services IDs (Sign in with Apple)
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_SERVICES_ID=com.forme.fitness.signin
APPLE_KEY_ID=R8S2XHD8K7
APPLE_KEY_PATH=AuthKey_R8S2XHD8K7.p8
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...
EXPO_PUBLIC_ANTHROPIC_MODEL=claude-sonnet-4-6
# 코치 AI — 설정 모달에서도 입력 가능 (없으면 .env 폴백)
EXPO_PUBLIC_OPENAI_API_KEY=sk-...
# Goal 위저드 — 분석(chat) + 목표 이미지(generations)
# gpt-image 계열은 이미지 전용. 분석에는 gpt-4o-mini 등 chat 모델 사용.
EXPO_PUBLIC_OPENAI_CHAT_MODEL=gpt-4o-mini
EXPO_PUBLIC_OPENAI_IMAGE_MODEL=gpt-image-2
# 하위 호환: CHAT/IMAGE 미설정 시 이 값 사용 (이미지 모델이면 분석은 gpt-4o-mini 폴백)
EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_REPLICATE_API_TOKEN=r8_...
# RapidAPI → ExerciseDB (https://rapidapi.com/hub 에서 ExerciseDB 구독 후 키 입력)
EXPO_PUBLIC_RAPIDAPI_KEY=
